# ============================================================
#  daq-kafka-broker 설정
#  이 파일만 수정하면 됩니다.
# ============================================================

# ── MinIO 151번 ───────────────────────────────────────────────
MINIO_ENDPOINT=http://192.168.1.151:9001
MINIO_ACCESS_KEY=swmadmin
MINIO_SECRET_KEY=LUn?O4lZGl**el/m=3E^Xx9%NKNc}gR?
MINIO_BUCKET=daq

# ── Kafka Topic ───────────────────────────────────────────────
# 추가/변경 시 여기만 수정 후 ./start.sh 재실행
KAFKA_TOPICS=sensor.cam0.jpeg,sensor.cam1.jpeg,sensor.cam2.jpeg,sensor.gnss

# ── Kafka 보존 설정 ───────────────────────────────────────────
KAFKA_LOG_RETENTION_HOURS=72
KAFKA_LOG_RETENTION_BYTES=107374182400
KAFKA_MESSAGE_MAX_BYTES=10485760

# ── Consumer ──────────────────────────────────────────────────
CONSUMER_MAX_WORKERS=4
CONSUMER_LOG_LEVEL=INFO

# ── SMTP (Cloudflare URL 메일 발송) ───────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password       # Gmail 앱 비밀번호 (2단계 인증 후 발급)
SMTP_TO=your-email@gmail.com          # 수신 이메일
