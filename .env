# ============================================================
#  daq-kafka-broker  통합 설정
#  이 파일만 수정하면 됩니다.
# ============================================================

# ── 외부 접근 URL ─────────────────────────────────────────────
RED_EDGE_PUBLIC_URL=https://221.147.232.196:8443

# ── MinIO ─────────────────────────────────────────────────────
MINIO_ROOT_USER=swm
MINIO_ROOT_PASSWORD=Q7mN2xvP9rT4kL8sW3zB6yHcD5fJ1aXe
MINIO_BUCKET=daq
MINIO_PROMETHEUS_AUTH_TYPE=public

# ── Postgres ──────────────────────────────────────────────────
POSTGRES_DB=redpoc
POSTGRES_USER=redpoc
POSTGRES_PASSWORD=oracle321!@

# ── Grafana ───────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=swm-grafana-2026
GF_SERVER_ROOT_URL=https://221.147.232.196:8443/poc/grafana/
GF_SERVER_SERVE_FROM_SUB_PATH=true

# ── EMQX ──────────────────────────────────────────────────────
EMQX_ALLOW_ANONYMOUS=false
EMQX_WS_ENABLED=true

# ── Kafka ─────────────────────────────────────────────────────
KAFKA_MESSAGE_MAX_BYTES=10485760       # 카메라 JPEG 최대 10MB
KAFKA_LOG_RETENTION_HOURS=72           # 기본 보존 72시간
KAFKA_LOG_RETENTION_BYTES=107374182400 # 기본 보존 100GB

# ── Kafka Image Consumer ──────────────────────────────────────
IMAGE_CONSUMER_LOG_LEVEL=INFO
IMAGE_CONSUMER_METRICS_PORT=2118

# ── Kafka IMU Archiver ────────────────────────────────────────
IMU_ARCHIVER_BATCH_SIZE=1000           # parquet flush 배치 크기
IMU_ARCHIVER_IDLE_FLUSH_SEC=90         # idle flush 대기 시간(초)
IMU_ARCHIVER_LOG_LEVEL=INFO
IMU_ARCHIVER_METRICS_PORT=2121

# ── Kafka Frame Bridge ────────────────────────────────────────
FRAME_BRIDGE_BUNDLE_WINDOW_MS=1000     # 번들 윈도우(ms), 1000=1Hz
FRAME_BRIDGE_SENSORS_EXPECTED=0        # 0=window만, 3=3센서 도달시 즉시
FRAME_BRIDGE_LOG_LEVEL=INFO
FRAME_BRIDGE_METRICS_PORT=2120

# ── Processor (Java) ──────────────────────────────────────────
PROCESSOR_METRICS_PORT=2115
PROCESSOR_CONFIDENCE_THRESHOLD=0.4     # YOLO 검출 신뢰도 임계값
PROCESSOR_TRITON_TIMEOUT_MS=5000       # Triton 추론 타임아웃(ms)
PROCESSOR_VISUALIZE_ENABLED=true       # bbox 시각화 결과 MinIO 저장
PROCESSOR_VISUALIZE_JPEG_QUALITY=85    # 시각화 JPEG 품질
PROCESSOR_GPS_KIND=file                # file | kafka | none

# ── Notifier (Java) ───────────────────────────────────────────
NOTIFIER_METRICS_PORT=2116
NOTIFIER_KIND=file_log                 # noop | file_log | slack
NOTIFIER_SLACK_TOKEN=                  # slack 사용시 입력
NOTIFIER_SLACK_CHANNEL=#road-events

# ── Transcoder ────────────────────────────────────────────────
TRANSCODER_METRICS_PORT=2114

# ── DAQ Consumer (차량 센서 → MinIO) ─────────────────────────
DAQ_CONSUMER_MAX_WORKERS=4
DAQ_CONSUMER_LOG_LEVEL=INFO

# ── 차량 Topic 설정 ───────────────────────────────────────────
TOPIC_CAM0=sensor.cam0.jpeg
TOPIC_CAM1=sensor.cam1.jpeg
TOPIC_CAM2=sensor.cam2.jpeg
TOPIC_GNSS=sensor.gnss

# ── triton ──────────────────────────────────────────────────
TRITON_MODEL_REPO=./triton/model_repository