# ============================================================
#  daq-kafka-broker 설정
#  이 파일만 수정하면 됩니다.
#  (MinIO 인증키는 config/minio.secret 에서 관리)
# ============================================================

# ── Kafka ─────────────────────────────────────────────────────
KAFKA_CLUSTER_ID=daq-kraft-cluster-001
KAFKA_LOG_RETENTION_HOURS=72
KAFKA_LOG_RETENTION_BYTES=107374182400

# ── Topic ─────────────────────────────────────────────────────
TOPIC_CAM0=sensor.cam0.jpeg
TOPIC_CAM1=sensor.cam1.jpeg
TOPIC_CAM2=sensor.cam2.jpeg
TOPIC_GNSS=sensor.gnss
TOPIC_PARTITIONS=3
TOPIC_REPLICATION=1

# ── MinIO 151번 ───────────────────────────────────────────────
MINIO_ENDPOINT=http://192.168.1.151:9001
MINIO_BUCKET=daq

# ── Consumer ──────────────────────────────────────────────────
CONSUMER_MAX_WORKERS=4
CONSUMER_METRICS_PORT=2122
