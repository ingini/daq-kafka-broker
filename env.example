# ============================================================
#  daq-kafka-broker 설정 템플릿
#  cp .env.example .env 후 <...> 부분을 실제 값으로 교체
# ============================================================

# ── 외부 접근 URL ─────────────────────────────────────────────
RED_EDGE_PUBLIC_URL=https://<PUBLIC_IP>:<PORT>

# ── MinIO ─────────────────────────────────────────────────────
MINIO_ROOT_USER=<MinIO 계정>
MINIO_ROOT_PASSWORD=<MinIO 비밀번호>
MINIO_BUCKET=daq
MINIO_PROMETHEUS_AUTH_TYPE=public

# ── Postgres ──────────────────────────────────────────────────
POSTGRES_DB=redpoc
POSTGRES_USER=redpoc
POSTGRES_PASSWORD=<DB 비밀번호>

# ── Grafana ───────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=<Grafana 비밀번호>
GF_SERVER_ROOT_URL=https://<PUBLIC_IP>:<PORT>/poc/grafana/
GF_SERVER_SERVE_FROM_SUB_PATH=true

# ── EMQX ──────────────────────────────────────────────────────
EMQX_ALLOW_ANONYMOUS=false
EMQX_WS_ENABLED=true

# ── Kafka ─────────────────────────────────────────────────────
KAFKA_MESSAGE_MAX_BYTES=10485760
KAFKA_LOG_RETENTION_HOURS=72
KAFKA_LOG_RETENTION_BYTES=107374182400

# ── Kafka Image Consumer ──────────────────────────────────────
IMAGE_CONSUMER_LOG_LEVEL=INFO
IMAGE_CONSUMER_METRICS_PORT=2118

# ── Kafka IMU Archiver ────────────────────────────────────────
IMU_ARCHIVER_BATCH_SIZE=1000
IMU_ARCHIVER_IDLE_FLUSH_SEC=90
IMU_ARCHIVER_LOG_LEVEL=INFO
IMU_ARCHIVER_METRICS_PORT=2121

# ── Kafka Frame Bridge ────────────────────────────────────────
FRAME_BRIDGE_BUNDLE_WINDOW_MS=1000
FRAME_BRIDGE_SENSORS_EXPECTED=0
FRAME_BRIDGE_LOG_LEVEL=INFO
FRAME_BRIDGE_METRICS_PORT=2120

# ── Triton / Model ────────────────────────────────────────────
TRITON_MODEL_NAME=yolo26n
TRITON_IMGSZ=640
TRITON_OPSET=12

# ── Processor ─────────────────────────────────────────────────
PROCESSOR_METRICS_PORT=2115
PROCESSOR_CONFIDENCE_THRESHOLD=0.4
PROCESSOR_TRITON_TIMEOUT_MS=5000
PROCESSOR_VISUALIZE_ENABLED=true
PROCESSOR_VISUALIZE_JPEG_QUALITY=85
PROCESSOR_GPS_KIND=file

# ── Notifier ──────────────────────────────────────────────────
NOTIFIER_METRICS_PORT=2116
NOTIFIER_KIND=file_log
NOTIFIER_SLACK_TOKEN=
NOTIFIER_SLACK_CHANNEL=#road-events

# ── Transcoder ────────────────────────────────────────────────
TRANSCODER_METRICS_PORT=2114

# ── DAQ Consumer ─────────────────────────────────────────────
DAQ_CONSUMER_MAX_WORKERS=4
DAQ_CONSUMER_LOG_LEVEL=INFO

# ── 차량 Topic ────────────────────────────────────────────────
TOPIC_CAM0=sensor.cam0.jpeg
TOPIC_CAM1=sensor.cam1.jpeg
TOPIC_CAM2=sensor.cam2.jpeg
TOPIC_GNSS=sensor.gnss
